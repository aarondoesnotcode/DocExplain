# Z.ai API key used for document analysis
ZAI_API_KEY=your_zai_api_key_here

# Optional text model override. Defaults to glm-5-turbo
ZAI_MODEL=glm-5-turbo

# Optional vision model override for image uploads. Defaults to glm-5v-turbo
ZAI_VISION_MODEL=glm-5v-turbo

# Optional but recommended for more reliable OCR on document images
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
